# =============================================================================
# Hotel Website — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Sensitive / Environment Config
# -----------------------------------------------------------------------------
config/
.env
.env.*
*.local.php

# -----------------------------------------------------------------------------
# XAMPP / PHP Logs
# -----------------------------------------------------------------------------
*.log
logs/
error_log

# -----------------------------------------------------------------------------
# Uploaded / Generated Files
# -----------------------------------------------------------------------------
assets/uploads/
public/uploads/
uploads/

# -----------------------------------------------------------------------------
# SQL Dumps (keep schema, ignore data dumps)
# -----------------------------------------------------------------------------
sql/*.sql.bak
sql/*_dump.sql
sql/*_backup.sql

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Editor / IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Node / npm (if any tooling is used)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-error.log
package-lock.json

# -----------------------------------------------------------------------------
# Composer (PHP dependencies)
# -----------------------------------------------------------------------------
vendor/
composer.lock

# -----------------------------------------------------------------------------
# Compiled / Cache
# -----------------------------------------------------------------------------
*.cache
*.tmp
*.bak
